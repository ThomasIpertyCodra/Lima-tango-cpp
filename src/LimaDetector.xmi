    <deviceProperties name="MemorizedAcquisitionMode" description="Memorize/Define the acquisitionMode attribute at Init device&lt;br>&#xA;Availables values :&lt;br>&#xA;- SINGLE&lt;br>&#xA;- ACCUMULATION&lt;br>">
