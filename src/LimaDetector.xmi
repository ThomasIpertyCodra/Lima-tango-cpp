    <commands name="Start" description="Starts a &quot;video/live&quot; acquisition of an infinite number of frames.&lt;br>&#xA;In this mode, In this mode, the frame loss is permitted and not signaled as FAULT in the device state&lt;br>&#xA;It is not allowed to generate files in this mode." execMethod="start" displayLevel="OPERATOR" polledPeriod="0">
      <argin description="">
        <type xsi:type="pogoDsl:VoidType"/>
      </argin>
      <argout description="">
        <type xsi:type="pogoDsl:VoidType"/>
      </argout>
