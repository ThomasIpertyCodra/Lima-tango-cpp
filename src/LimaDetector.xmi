      <DefaultPropValue>Module</DefaultPropValue>
      <DefaultPropValue>Type</DefaultPropValue>
      <DefaultPropValue>Funct</DefaultPropValue>
    </deviceProperties>
    <deviceProperties name="ExpertBufferMaxMemoryPercent" description="Define the Percent of Memory reserved to Lima buffer control.&lt;br>&#xA;BufferMaxMemoryPercent = 70, allow a Memory of 1.4 Go. (Default)&lt;br>&#xA;BufferMaxMemoryPercent = 100, allow a Memory of 2 Go. (Maximum)">
      <type xsi:type="pogoDsl:UShortType"/>
      <status abstract="false" inherited="false" concrete="true" concreteHere="true"/>
      <DefaultPropValue>70</DefaultPropValue>
    </deviceProperties>
    <deviceProperties name="ExpertNbPoolThread" description="Defines the number of threads dedicated to process images in the ProcessLib">
      <type xsi:type="pogoDsl:UShortType"/>
      <status abstract="false" inherited="false" concrete="true" concreteHere="true"/>
      <DefaultPropValue>4</DefaultPropValue>
    </deviceProperties>
    <deviceProperties name="ExpertTimeoutCmd" description="Define the Timeout (in ms) for some commands (snap/start/stop/prepare).&lt;br>">
      <type xsi:type="pogoDsl:UIntType"/>
      <status abstract="false" inherited="false" concrete="true" concreteHere="true"/>
      <DefaultPropValue>5000</DefaultPropValue>
    </deviceProperties>
    <deviceProperties name="ExpertAllowMixedRoiBinning" description="Define whether the simultaneous use of binning and ROI is allowed">
      <type xsi:type="pogoDsl:BooleanType"/>
      <status abstract="false" inherited="false" concrete="true" concreteHere="true"/>
